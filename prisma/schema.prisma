generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  chunks    DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(cuid())
  noteId     String
  content    String
  chunkIndex Int
  createdAt  DateTime @default(now())
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}
